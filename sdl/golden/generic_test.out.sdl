forge:options {
    go_auto_generate
    go_package "std"
    go_import_as "github.com/art-media-platform/amp.SDK/amp/std"
    csharp_auto_generate
    csharp_namespace "art.media.platform"
}

std {
    Session
    App
    AppModule
    Planet
    Globe
    Item
    Tile
}

std.Session {
    LoginStart
    LoginChallenge
    LoginResponse
    SessionCheckpoint.Tags
    Message.Tags
    Launch.Tags
    Launch.Tags.OAuth
    PinRequest
    PinAdjust.Tags
}

std.Item {
    Text.Tag {
        Label
        Caption
        Collection
        Synopsis
    }
    Layout.Tags
    Theme.Tags
    Some.SubScope {
        Apples
        Oranges
    }
    Link.ID
}

std.Content {
    FSInfo
    Glyph.Tags
    Media.Tag
    Vis.Invocation.Tags
    Vis.Preset.Tags
    Type {
        Image "image/*"
        Audio "audio/*"
        Video "video/*"
        Directory "application/x-directory"
        URI_Prefix "amp:glyph/"
    }
}

std.Tile {
    Layout
    Theme.Tags
}

std.Channel {
    Space.Globe
    Space.Local
    Notes
    Documents
    Journal
    Calendar
    Timeline
    Messages
    Spreadsheet
    Playlist
    Playlist.VJ
    LinkTree
}

amp.test {
    f0 45.67
    f1 0.64
    f2 0.64
    f3 0.64
    f3 45.
    someInt 123
    someStr "Hello, World!"
    someBool true
    someDate 2023-10-31
    someTime 14:30:15
    someDateTime 2023-10-31 T14:30:15Z
    someNull null
}

std.UICard {
    std.Pen.State {
        step.right "3:00"
        step.newline "6:00"
        std.Glyph.aspect 1. x=0 y=0 direction=3
    }
    std.Layout.Path direction="3:00" thick=10 kern=2 {
        std.Glyph height=10 "amp:glyph/std.select.location"
        std.Heading height=6 "Select Location\n"
        std.Caption height=4 "Choose the first half of your member ID\n\n"
        std.TileSelector
    }
    std.Layout.Story {
        std.Layout.Column {
            std.Heading {
                std.Glyph height=10 "amp:glyph/std.select.location"
                std.Title height=6 "Select Location"
                std.Caption height=4 "This is the first half of your public ID and can be anywhere "
            }
            std.TextField {
                std.Label height=4 "Location"
                std.Caption height=3 "City, State, Country"
            }
            std.OneOf {
                std.value.binding "welcome.ID.generate.step.1"
            }
        }
    }
}

amp.menu.std.inserter.rectangular {
    insert.start.ij [0,0]
    insert.cell.size.ij [4,1]
    insert.cell.step.ij [5,0]
    page.columns 2
    page.rows 10
    page.step.ij [80,0]
}

