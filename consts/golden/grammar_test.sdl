// grammar_test.sdl — forge const grammar regression fixture.
//
// This file exercises every production in the forge const grammar:
// nested `tags` hierarchies, single- and multi-line doc comments,
// scalar constants (uint64, float32/64, string, hex literals, uid pairs),
// and grouped `const` structs with their own doc comments.
//
// The generated outputs (grammar_test.consts.go + grammar_test.consts.cs)
// must preserve comment text verbatim, compute stable BLAKE2-style hashes
// for every tag name, and align declarations into tidy columns.  The golden
// round-trip asserts all three properties on every forge change.

option go_package = "github.com/art-media-platform/amp.SDK/amp/std";
option csharp_namespace = "art.media.platform.std";

tags Name {

    // This is a big fancy comment,
    name AppTag "app" {
        AppState "state"
    }

    // This is a very descriptive comment
    // that spans multiple lines to exercise
    // the multi-line doc-comment code path.
    name SessionAttr "session" {
        LoginID "Login"
        name SessionTag "Tag" {
            LaunchWeb "www"

            name ReallySuperLongName "ReallySuperLongName"
        }
    }
}

// Bootstrapping node ID
const uid TestingID = {0x7, 0x8};

// Scalar string constants
const uint64 MaxFraction     = 1000000000;
const uint64 HexConst        = 0xFFFFFFFFFFFFFFF0;
const float64 Pi             = 3.14159265358979;
const float32 SmallPi        = 3.14;
const double  TwoPi          = 3.14159265358979;

const Moar {
    uint64 MaxFraction     = 1000000000;
    double  TwoPi          = 3.14159265358979;
    string Striiing        = "hello sailor";
}


const Glyph {
    string WebLink     = "asset:glyph/web.link";
    string DefaultNode = "asset:glyph/default.node";
}

const Herro {
    string WebLink = "fooled you";
    string DefaultNode = "default this";
}

// Mixed-type group: scalars emit as const, UIDs as var (Go forbids struct
// literals in const blocks).  Flat-prefixed by the group name — access is
// `std.SessionContextID` + `std.SessionLaunchPath`.
const Session {
    uid ContextID = {0x0, 0x777};
    string LaunchPath = "/session/start";
}